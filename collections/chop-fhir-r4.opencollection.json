{
  "opencollection": "1.0.0",
  "info": {
    "name": "Children's Hospital of Philadelphia FHIR R4 API",
    "version": "4.0.1"
  },
  "request": {
    "auth": {
      "type": "oauth2",
      "flow": "client_credentials",
      "accessTokenUrl": "https://epicnsproxy.chop.edu/fhir/oauth2/token",
      "credentials": {
        "clientId": "{{clientId}}",
        "clientSecret": "{{clientSecret}}"
      }
    }
