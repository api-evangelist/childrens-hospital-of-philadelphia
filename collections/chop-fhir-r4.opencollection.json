        "type": "folder"
      },
      "items": [
        {
          "info": {
            "name": "Export Group Bulk Data",
            "type": "http"
          },
          "http": {
            "method": "GET",
            "url": "https://epicnsproxy.chop.edu/fhir/api/FHIR/R4/Group/:id/$export",
            "params": [
              {
                "name": "id",
                "value": "",
                "type": "path"
              },
              {
                "name": "_type",
                "value": "",
                "type": "query"
              }
            ]
          },
          "docs": "Initiates a Bulk Data (Flat FHIR) export for a Group of patients per\nHL7 FHIR Bulk Data Access IG. Requires client_credentials authentication and the\n`system/*.read` scope. Status is polled at the Content-Location URL.\n"
        }
